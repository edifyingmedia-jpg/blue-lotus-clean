{
  "name": "basic-builder",
  "label": "Basic Builder",
  "description": "A minimal starter builder template for Blue Lotus.",
  "manifest": [
    {
      "name": "Button",
      "label": "Button",
      "description": "A clickable button component.",
      "props": {
        "text": {
          "type": "string",
          "default": "Click me"
        },
        "variant": {
          "type": "string",
          "default": "primary"
        }
      }
    },
    {
      "name": "Card",
      "label": "Card",
      "description": "A simple container card.",
      "props": {
        "title": {
          "type": "string",
          "default": "Card Title"
        },
        "body": {
          "type": "string",
          "default": "Card content goes here."
        }
      }
    }
  ],
  "tokens": {
    "color": {
      "background": "#071018",
      "surface": "#0b1220",
      "text": "#e6eef2",
      "primary": "#06b6d4"
    },
    "spacing": {
      "sm": 8,
      "md": 16,
      "lg": 24
    }
  },
  "nodes": [
    {
      "type": "Card",
      "props": {
        "title": "Welcome",
        "body": "This is your starter builder template."
      }
    }
  ]
}
